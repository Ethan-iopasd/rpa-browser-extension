{
  "manifest_version": 3,
  "name": "RPA Flow Recorder",
  "version": "0.1.0",
  "description": "Capture browser interactions for RPA node generation.",
  "key": "",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "tabs", "storage", "scripting", "nativeMessaging", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ]
}
