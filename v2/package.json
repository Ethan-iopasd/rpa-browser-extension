{
  "name": "rpa-flow-v2",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev:designer": "pnpm --filter @rpa/designer dev",
    "dev:desktop": "pnpm --filter @rpa/desktop dev:tauri",
    "build:designer": "pnpm --filter @rpa/designer build",
    "build:desktop": "pnpm --filter @rpa/desktop build:tauri",
    "build": "pnpm build:designer",
    "lint:designer": "pnpm --filter @rpa/designer lint",
    "lint:schema": "pnpm --filter @rpa/flow-schema lint",
    "lint:python": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run_python310.ps1 scripts/python_syntax_check.py",
    "lint": "pnpm lint:designer && pnpm lint:schema && pnpm lint:python",
    "typecheck:designer": "pnpm --filter @rpa/designer typecheck",
    "typecheck:schema": "pnpm --filter @rpa/flow-schema typecheck",
    "typecheck:python": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run_python310.ps1 scripts/python_syntax_check.py",
    "typecheck": "pnpm typecheck:designer && pnpm typecheck:schema && pnpm typecheck:python",
    "test:python": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run_python310.ps1 -m unittest discover -s tests -p \"test_*.py\"",
    "test:python:310": ".\\.venv310\\Scripts\\python.exe -m unittest discover -s tests -p \"test_*.py\"",
    "test:picker:smoke": "node apps/recorder-extension/tests/picker_route_smoke.mjs",
    "test": "pnpm test:python && pnpm test:picker:smoke",
    "ops:soak": "python scripts/ops/soak_test.py",
    "ops:perf": "python scripts/ops/perf_benchmark.py",
    "ops:regression": "python scripts/ops/regression_gate.py",
    "pack:recorder-extension": "powershell -ExecutionPolicy Bypass -File .\\scripts\\release\\package_recorder_extension.ps1",
    "release:beta": "powershell -ExecutionPolicy Bypass -File .\\scripts\\release\\build_beta_package.ps1",
    "release:desktop:sidecar": "powershell -ExecutionPolicy Bypass -File .\\scripts\\release\\build_api_sidecar.ps1",
    "release:desktop": "powershell -ExecutionPolicy Bypass -File .\\scripts\\release\\build_desktop_installer.ps1",
    "release:desktop:fast": "powershell -ExecutionPolicy Bypass -File .\\scripts\\release\\build_desktop_installer.ps1 -SkipChecks",
    "release:desktop:manifest": "powershell -ExecutionPolicy Bypass -File .\\scripts\\release\\build_desktop_installer.ps1 -SkipChecks -SkipBuild",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "schema:generate": "pnpm --filter @rpa/flow-schema generate",
    "schema:check": "pnpm --filter @rpa/flow-schema check:sync"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "^3.7.3",
    "typescript-eslint": "^8.46.4"
  }
}
